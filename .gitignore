# 忽略 .idea 下所有文件，再手动包含共享配置
.idea/*

# 包含共享配置
!.idea/codeStyles/
!.idea/codeStyles/**
!.idea/inspectionProfiles/
!.idea/inspectionProfiles/**
!.idea/encodings.xml
!.idea/vcs.xml
!.idea/misc.xml
!.idea/runConfigurations/
!.idea/runConfigurations/**

# 忽略操作系统临时文件
.DS_Store
Thumbs.db

# 忽略编译输出目录
out/
target/
build/
bin/